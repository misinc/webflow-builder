{
  "name": "webflow-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/backend-core",
    "visual-qa"
  ],
  "scripts": {
    "start": "npm --workspace webflow-builder-visual-qa start",
    "build": "npm run build:backend && npm run build:extension",
    "build:backend": "tsc -p tsconfig.node.json",
    "build:extension": "vite build --config vite.extension.config.ts",
    "build:visual-qa": "npm --workspace webflow-builder-visual-qa run build",
    "bundle:extension": "npm run build && webflow extension bundle",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.extension.json",
    "test": "vitest run"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^0.468.0",
    "node-html-parser": "^8.0.3",
    "postcss": "^8.5.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
